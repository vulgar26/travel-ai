# 复制本文件为 .env 后填写（.env 已在 .gitignore，勿提交）
# docker compose 会自动读取当前目录下的 .env 用于变量替换
#
# 可选：直连 Docker Hub 时覆盖镜像名（默认 compose 已用 DaoCloud 代理路径）
# POSTGRES_IMAGE=pgvector/pgvector:pg16
# REDIS_IMAGE=redis:7-alpine

# PostgreSQL（与 compose 中 postgres 服务一致）
POSTGRES_PASSWORD=postgres

# JWT HS256：须足够长，避免 WeakKeyException（示例为 64 个十六进制字符）
APP_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# 通义千问（对话 / 向量化均依赖；不填则相关功能不可用）
SPRING_AI_DASHSCOPE_API_KEY=

# 可选：和风等天气 Key
# WEATHER_API_KEY=
